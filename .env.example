# Macro Intel — Environment Variables
# Copy to .env and fill in your API keys.
# All keys are optional — the app works without them (graceful fallback).

# ---- Cloudflare Worker RSS Proxy -------------------------------------------
# Local dev: http://localhost:8787
# Production: https://macro-intel-rss-proxy.<your-subdomain>.workers.dev
VITE_WORKER_URL=

# ---- FRED (Federal Reserve Economic Data) ----------------------------------
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# 120 requests/min
VITE_FRED_API_KEY=

# ---- Alpha Vantage (Stocks, FX, Crypto, Economic Indicators) --------------
# Free key: https://www.alphavantage.co/support/
# 25 requests/day (free tier)
VITE_ALPHA_VANTAGE_KEY=

# ---- Finnhub (Real-time Markets, Economic Calendar, Sentiment) -------------
# Free key: https://finnhub.io/
# 60 requests/min
VITE_FINNHUB_KEY=

# ---- Twelve Data (Stocks, FX, Crypto, Commodities, Technicals) ------------
# Free key: https://twelvedata.com/
# 800 requests/day
VITE_TWELVE_DATA_KEY=

# ---- Marketaux (Financial News + Sentiment) --------------------------------
# Free key: https://www.marketaux.com/
# 100 requests/day
VITE_MARKETAUX_KEY=

# ---- NewsAPI (General News) ------------------------------------------------
# Free key: https://newsapi.org/
# 100 requests/day, 1 month lookback
VITE_NEWSAPI_KEY=

# ---- No API Key Required ---------------------------------------------------
# These work out of the box:
# - World Bank Open Data (https://data.worldbank.org/)
# - DB.nomics (https://db.nomics.world/)
# - Our World in Data (https://ourworldindata.org/)
# - Eurostat (https://ec.europa.eu/eurostat)
# - IMF Data (https://data.imf.org/)
# - FAOSTAT (https://www.fao.org/faostat/)
# - OECD (https://data.oecd.org/)
# - UN Data (https://data.un.org/)
